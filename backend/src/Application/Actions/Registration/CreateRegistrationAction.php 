<?php

declare(strict_types=1);

namespace App\Application\Actions\Registration;

use App\Application\Response\ApiResponse;
use App\Domain\Registration\RegistrationService;
use Psr\Http\Message\ResponseInterface as Response;
use Psr\Http\Message\ServerRequestInterface as Request;

final class CreateRegistrationAction
{
    public function __construct(
        private RegistrationService $registrationService,
        private ApiResponse $response,
    ) {
    }

    public function __invoke(Request $request, Response $response, array $args): Response
    {
        $eventId = $args['id'];
        $userId = 'replace-with-auth-user-id';

        $result = $this->registrationService->registerForEvent($eventId, $userId);

        return $this->response->json($response, [
            'data' => $result,
        ], 201);
    }
}
