<?php

declare(strict_types=1);

use App\Application\Response\ApiResponse;
use App\Domain\Auth\AuthService;
use App\Domain\Auth\PasswordHasher;
use App\Domain\Auth\TokenService;
use App\Domain\Event\EventService;
use App\Domain\Registration\RegistrationService;
use App\Domain\Registration\WaitlistService;
use App\Infrastructure\Queue\RedisStreamPublisher;
use App\Infrastructure\Security\JwtTokenService;
use App\Infrastructure\Security\PhpPasswordHasher;
use DI\ContainerBuilder;
use Predis\Client as PredisClient;
use PDO;

$builder = new ContainerBuilder();

$builder->addDefinitions([
    PDO::class => function () {
        $dsn = sprintf(
            'mysql:host=%s;port=%s;dbname=%s;charset=utf8mb4',
            $_ENV['DB_HOST'],
            $_ENV['DB_PORT'],
            $_ENV['DB_NAME']
        );

        return new PDO($dsn, $_ENV['DB_USER'], $_ENV['DB_PASS'], [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
        ]);
    },
    PredisClient::class => fn () => new PredisClient([
        'scheme' => 'tcp',
        'host' => $_ENV['REDIS_HOST'],
        'port' => (int) $_ENV['REDIS_PORT'],
    ]),
    PasswordHasher::class => DI\autowire(PhpPasswordHasher::class),
    TokenService::class => DI\autowire(JwtTokenService::class),
    RedisStreamPublisher::class => DI\autowire(),
    AuthService::class => DI\autowire(),
    EventService::class => DI\autowire(),
    WaitlistService::class => DI\autowire(),
    RegistrationService::class => DI\autowire(),
    ApiResponse::class => DI\autowire(),
]);

return $builder->build();
